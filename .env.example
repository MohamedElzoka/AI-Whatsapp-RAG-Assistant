# Copy this file to `.env` in the project root and fill in real values.
# NEVER commit your actual .env file to version control.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=rag_assistant
# DATABASE_URL is assembled automatically in docker-compose.yml from the
# values above; only set it directly if running the backend outside Docker.
# DATABASE_URL=postgresql+psycopg2://rag_user:change-this-strong-password@localhost:5432/rag_assistant

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
# QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-with-your-real-key
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# RAG / escalation tuning
# ---------------------------------------------------------------------------
RAG_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120
SIMILARITY_THRESHOLD=0.55
CONFIDENCE_ESCALATION_THRESHOLD=0.45

# ---------------------------------------------------------------------------
# WhatsApp Cloud API
# (from https://developers.facebook.com -> your App -> WhatsApp -> API Setup)
# ---------------------------------------------------------------------------
WHATSAPP_TOKEN=replace-with-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-with-waba-id
WHATSAPP_VERIFY_TOKEN=choose-a-random-verify-token
WHATSAPP_APP_SECRET=replace-with-app-secret
WHATSAPP_API_VERSION=v20.0
# Optional: internal staff number to auto-notify on escalation (E.164, no +)
HUMAN_ESCALATION_PHONE=

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
SECRET_KEY=replace-with-a-long-random-string
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=replace-with-a-generated-fernet-key
# Shared secret between the backend and the Streamlit dashboard
ADMIN_API_KEY=replace-with-a-long-random-admin-key
CORS_ALLOW_ORIGINS=["*"]

# ---------------------------------------------------------------------------
# Uploads / logging
# ---------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=25
LOG_LEVEL=INFO
